# =============================================================================
# phishGPT Environment Configuration
# Copy this to .env and fill in your values
# =============================================================================

# --- MongoDB (overridden in docker-compose, set here for local dev) ----------
DB_URL=mongodb://localhost:27017
DB_NAME=gpt_app
DB_COLLECTION=gpt_app

# --- Flask API ---------------------------------------------------------------
# BASE_APP is overridden in docker-compose; set here for local dev
BASE_APP=http://localhost:5000

# --- Worker polling interval (seconds) --------------------------------------
POLL_INTERVAL=4

# --- AI Backend --------------------------------------------------------------
# "ollama" (default) or "claude"
AI_BACKEND=ollama

# Ollama settings (used when AI_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.3

# Claude settings (used when AI_BACKEND=claude or per-job override)
# ANTHROPIC_API_KEY=XXXXXXXXXXXX
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Net tools ---------------------------------------------------------------
IP2LOC_DB_PATH=/opt/data/IP2LOCATION-LITE-DB11.BIN

# --- Screenshot --------------------------------------------------------------
PAGE_LOAD_WAIT=3
REDIRECT_TIMEOUT=10

# --- Discord notifications (optional) ---------------------------------------------------
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
